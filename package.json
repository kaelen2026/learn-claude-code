{
  "name": "learn-claude-code-ts",
  "version": "1.0.0",
  "description": "Learning Claude Code implementation in TypeScript",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "chat": "tsx src/index.ts chat",
    "task": "tsx src/index.ts task",
    "memory": "tsx src/index.ts memory",
    "schedule": "tsx src/index.ts schedule",
    "team": "tsx src/index.ts team",
    "worktree": "tsx src/index.ts worktree",
    "mcp": "tsx src/index.ts mcp",
    "example:minimal": "tsx src/examples/minimal-agent.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "s01": "tsx src/legacy-stages/s01-agent-loop.ts",
    "s02": "tsx src/legacy-stages/s02-tool-use.ts",
    "s03": "tsx src/legacy-stages/s03-todo-write.ts",
    "s04": "tsx src/legacy-stages/s04-subagent.ts",
    "s05": "tsx src/legacy-stages/s05-skill-loading.ts",
    "s06": "tsx src/legacy-stages/s06-context-compact.ts",
    "s07": "tsx src/legacy-stages/s07-permission-system.ts",
    "s08": "tsx src/legacy-stages/s08-hook-system.ts",
    "s09": "tsx src/legacy-stages/s09-memory-system.ts",
    "s10": "tsx src/legacy-stages/s10-system-prompt.ts",
    "s11": "tsx src/legacy-stages/s11-error-recovery.ts",
    "s12": "tsx src/legacy-stages/s12-task-system.ts",
    "s13": "tsx src/legacy-stages/s13-background-tasks.ts",
    "s14": "tsx src/legacy-stages/s14-scheduled-tasks.ts",
    "s15": "tsx src/legacy-stages/s15-agent-teams.ts",
    "s16": "tsx src/legacy-stages/s16-team-protocols.ts",
    "s17": "tsx src/legacy-stages/s17-autonomous-agents.ts",
    "s18": "tsx src/legacy-stages/s18-worktree-isolation.ts",
    "s19": "tsx src/legacy-stages/s19-mcp-plugin.ts",
    "prepare": "husky"
  },
  "keywords": [
    "claude",
    "ai",
    "agent",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "chalk": "^5.6.2",
    "dotenv": "^17.4.1",
    "ora": "^9.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^22.19.17",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "*.{ts,js,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
